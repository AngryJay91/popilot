name = "{{project.name}}-pm-api"
main = "src/index.ts"
compatibility_date = "2025-03-10"

# Database credentials: npx wrangler secret put TURSO_URL && npx wrangler secret put TURSO_AUTH_TOKEN

# Proactive Nudge schedule (UTC)
