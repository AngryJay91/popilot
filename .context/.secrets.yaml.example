# 민감 정보 - 이 파일은 gitignore 대상입니다.
# 필요한 값을 채워주세요.
# Setup Wizard가 연동 설정에 따라 이 파일을 안내합니다.

# 예시 (프로젝트에 따라 다름)
INTEGRATIONS:
  # GA4_PROPERTY_ID: ""
  # NOTION_WORKSPACE: ""
  # CHANNEL_IO_ACCESS_KEY: ""
  # CHANNEL_IO_ACCESS_SECRET: ""
  # CORTI_API_KEY: ""          # Corti MCP Bearer token (MCP 설정에서 사용)

# 노션 태스크 연동 (선택)
NOTION_TASK:
  # USER_ID: ""
  # SPRINT_ID: ""

_META:
  UPDATED_AT: ""
  NOTE: "이 파일은 Git에 커밋되지 않습니다."
